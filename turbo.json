{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "OTTILI_CODER_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "OTTILI_CODER_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "ottili-coder#test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": ["*"]
    },
    "@ottili-coder/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@ottili-coder/ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
